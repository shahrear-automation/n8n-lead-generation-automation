    {
      "parameters": {
        "jsCode": "const leads = items.map(i => i.json);\n\nconst title = (leads?.[0]?.searchString || \"Google Maps Leads\").replace(/\\s+/g, ' ').trim();\nconst now = new Date().toLocaleString('en-GB', { timeZone: 'Asia/Dhaka' });\n\nconst rows = leads.map((d, idx) => {\n  const name = d.title || \"N/A\";\n  const phone = d.phone || \"N/A\";\n  const website = d.website || \"N/A\";\n  const address = d.address || \"N/A\";\n  return `\n    <div class=\"card\">\n      <div class=\"top\">\n        <div class=\"idx\">${idx + 1}</div>\n        <div class=\"name\">${name}</div>\n      </div>\n      <div class=\"addr\">${address}</div>\n      <div class=\"grid\">\n        <div class=\"pill\"><span>Phone</span><b>${phone}</b></div>\n        <div class=\"pill\"><span>Website</span><b>${website === \"N/A\" ? \"N/A\" : website}</b></div>\n      </div>\n    </div>\n  `;\n}).join(\"\");\n\nconst html = `<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\" />\n<title>Leads Report</title>\n<style>\n  @page { size: A4; margin: 18mm; }\n  body { font-family: Arial, sans-serif; color:#111; }\n  .header { display:flex; justify-content:space-between; align-items:flex-start; border-bottom: 2px solid #eee; padding-bottom: 12px; margin-bottom: 14px; }\n  .h1 { font-size: 18px; font-weight: 700; margin:0; }\n  .meta { font-size: 11px; color:#444; margin-top:6px; }\n  .badge { font-size: 11px; padding:6px 10px; border:1px solid #ddd; border-radius: 999px; background:#fafafa; }\n  .cards { display:flex; flex-direction:column; gap:10px; }\n  .card { border:1px solid #e6e6e6; border-radius: 12px; padding:12px; background:#fff; }\n  .top { display:flex; align-items:center; gap:10px; }\n  .idx { width:26px; height:26px; border-radius:8px; display:flex; align-items:center; justify-content:center; background:#111; color:#fff; font-size:12px; }\n  .name { font-size: 14px; font-weight: 700; }\n  .addr { margin-top:6px; font-size: 11px; color:#555; line-height: 1.35; }\n  .grid { margin-top:10px; display:grid; grid-template-columns: 1fr 1fr; gap:10px; }\n  .pill { border:1px dashed #ddd; border-radius: 10px; padding:10px; background:#fcfcfc; }\n  .pill span { display:block; font-size:10px; color:#666; margin-bottom:4px; text-transform: uppercase; letter-spacing: .06em; }\n  .pill b { font-size: 12px; word-break: break-word; }\n  .footer { margin-top: 14px; padding-top: 10px; border-top: 1px solid #eee; font-size: 10px; color:#666; }\n</style>\n</head>\n<body>\n  <div class=\"header\">\n    <div>\n      <div class=\"h1\">${title} — Leads Report</div>\n      <div class=\"meta\">Generated: ${now} (Dhaka) • Source: Google Maps</div>\n    </div>\n    <div class=\"badge\">Total: ${leads.length} leads</div>\n  </div>\n\n  <div class=\"cards\">\n    ${rows}\n  </div>\n\n  <div class=\"footer\">\n    Note: Emails usually are not available on Google Maps. If needed, we can enrich emails from websites in the next step.\n  </div>\n</body>\n</html>`;\n\nreturn [{ html }];"
      },
