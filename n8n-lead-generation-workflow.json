      "parameters": {
        "jsCode": "const raw = ($json.output || \"\").trim();\n\n// \"json\" prefix থাকলে বাদ দাও\nconst cleaned = raw.startsWith(\"json\")\n  ? raw.replace(/^json\\s*/i, \"\")\n  : raw;\n\n// Parse\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  // fallback: empty\n  parsed = { industry: null, location: null, limit: null };\n}\n\nreturn [{ ...parsed }];"
      },
